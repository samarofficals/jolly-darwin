{
    "layer": "top",
    "position": "bottom",
    "height": 56,
    "margin-bottom": 12,
    "spacing": 8,
    "width": 480,
    "modules-center": [
        "custom/term",
        "custom/files",
        "custom/browser",
        "custom/installer",
        "custom/code",
        "custom/settings",
        "custom/launcher"
    ],
    
    "custom/term": {
        "format": "",
        "on-click": "kitty",
        "tooltip-format": "Terminal"
    },
    "custom/files": {
        "format": "",
        "on-click": "thunar",
        "tooltip-format": "Files"
    },
    "custom/browser": {
        "format": "",
        "on-click": "firefox",
        "tooltip-format": "Browser"
    },
    "custom/installer": {
        "format": "󰏗",
        "on-click": "sudo -E calamares",
        "tooltip-format": "Install Usery OS"
    },
    "custom/code": {
        "format": "",
        "on-click": "kitty -e nano",
        "tooltip-format": "Text Editor"
    },
    "custom/settings": {
        "format": "⚙",
        "on-click": "kitty",
        "tooltip-format": "System Settings"
    },
    "custom/launcher": {
        "format": "",
        "on-click": "wofi --show drun",
        "tooltip-format": "App Launcher"
    }
}
